 {
     RKMPPDecodeContext *rk_context = avctx->priv_data;
     av_packet_unref(&rk_context->pending_pkt);
+    rkmpp_clear_dovi_queue(rk_context);
+    ff_dovi_ctx_unref(&rk_context->dovi);
     av_refstruct_unref(&rk_context->decoder);
     return 0;
 }
