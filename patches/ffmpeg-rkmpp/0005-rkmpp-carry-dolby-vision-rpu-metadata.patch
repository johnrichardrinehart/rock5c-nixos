+static void rkmpp_clear_dovi_queue(RKMPPDecodeContext *rk_context)
+{
+    for (int i = 0; i < FF_ARRAY_ELEMS(rk_context->dovi_queue); i++) {
+        av_buffer_unref(&rk_context->dovi_queue[i].metadata);
+        rk_context->dovi_queue[i].pts = AV_NOPTS_VALUE;
+    }
+}
+
+static int rkmpp_queue_dovi_metadata(AVCodecContext *avctx, int64_t pts)
+{
+    RKMPPDecodeContext *rk_context = avctx->priv_data;
+    AVDOVIMetadata *metadata = NULL;
+    AVBufferRef *buf;
+    int size;
+
+    if (pts == AV_NOPTS_VALUE)
+        return 0;
+
+    size = ff_dovi_get_metadata(&rk_context->dovi, &metadata);
+    if (size < 0)
+        return size;
+    if (!size)
+        return 0;
+
+    buf = av_buffer_create((uint8_t *)metadata, size, NULL, NULL, 0);
+    if (!buf) {
+        av_free(metadata);
+        return AVERROR(ENOMEM);
+    }
+
+    for (int i = 0; i < FF_ARRAY_ELEMS(rk_context->dovi_queue); i++) {
+        RKMPPDoviMetadata *entry = &rk_context->dovi_queue[i];
+
+        if (!entry->metadata || entry->pts == pts) {
+            av_buffer_unref(&entry->metadata);
+            entry->pts = pts;
+            entry->metadata = buf;
+            return 0;
+        }
+    }
+
+    av_log(avctx, AV_LOG_WARNING, "Dropping Dolby Vision metadata for PTS %"PRId64": queue full\n",
+           pts);
+    av_buffer_unref(&buf);
+    return 0;
+}
+
+static int rkmpp_attach_dovi_metadata(AVCodecContext *avctx, AVFrame *frame)
+{
+    RKMPPDecodeContext *rk_context = avctx->priv_data;
+
+    if (frame->pts == AV_NOPTS_VALUE)
+        return 0;
+
+    for (int i = 0; i < FF_ARRAY_ELEMS(rk_context->dovi_queue); i++) {
+        RKMPPDoviMetadata *entry = &rk_context->dovi_queue[i];
+
+        if (entry->metadata && entry->pts == frame->pts) {
+            AVBufferRef *metadata = av_buffer_ref(entry->metadata);
+            AVFrameSideData *sd;
+
+            if (!metadata)
+                return AVERROR(ENOMEM);
+
+            sd = av_frame_new_side_data_from_buf(frame, AV_FRAME_DATA_DOVI_METADATA, metadata);
+            if (!sd) {
+                av_buffer_unref(&metadata);
+                return AVERROR(ENOMEM);
+            }
+
+            av_buffer_unref(&entry->metadata);
+            entry->pts = AV_NOPTS_VALUE;
+            return 0;
+        }
+    }
+
+    return 0;
+}
+
+static int rkmpp_parse_hevc_dovi(AVCodecContext *avctx, const AVPacket *avpkt)
+{
+    RKMPPDecodeContext *rk_context = avctx->priv_data;
+    H2645Packet pkt = { 0 };
+    int ret;
+
+    if (avctx->codec_id != AV_CODEC_ID_HEVC || !avpkt->size)
+        return 0;
+
+    ret = ff_h2645_packet_split(&pkt, avpkt->data, avpkt->size, avctx, 0,
+                                AV_CODEC_ID_HEVC, H2645_FLAG_SMALL_PADDING);
+    if (ret < 0) {
+        av_log(avctx, AV_LOG_DEBUG, "Failed to split HEVC packet for Dolby Vision RPU parsing\n");
+        return 0;
+    }
+
+    if (pkt.nb_nals > 1 && pkt.nals[pkt.nb_nals - 1].type == HEVC_NAL_UNSPEC62 &&
+        pkt.nals[pkt.nb_nals - 1].size > 2 && !pkt.nals[pkt.nb_nals - 1].nuh_layer_id &&
+        !pkt.nals[pkt.nb_nals - 1].temporal_id) {
+        H2645NAL *nal = &pkt.nals[pkt.nb_nals - 1];
+
+        ret = ff_dovi_rpu_parse(&rk_context->dovi, nal->data + 2, nal->size - 2,
+                                avctx->err_recognition);
+        if (ret < 0) {
+            av_log(avctx, AV_LOG_WARNING, "Error parsing Dolby Vision RPU NAL unit\n");
+            ff_dovi_ctx_flush(&rk_context->dovi);
+        } else {
+            ret = rkmpp_queue_dovi_metadata(avctx, avpkt->pts);
+            if (ret < 0)
+                av_log(avctx, AV_LOG_WARNING, "Error queueing Dolby Vision metadata\n");
+        }
+    }
+
+    ff_h2645_packet_uninit(&pkt);
+    return 0;
+}
+
