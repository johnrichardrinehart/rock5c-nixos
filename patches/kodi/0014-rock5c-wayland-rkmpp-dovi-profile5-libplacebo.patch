+bool VideoPicture::HasDolbyVisionProfile5() const
+{
+  return hdrType == StreamHdrType::HDR_TYPE_DOLBYVISION && dovi.dv_profile == 5 &&
+         dovi.dv_bl_signal_compatibility_id == 0;
+}
+
+void VideoPicture::ApplyDolbyVisionProfile5ColorHints()
+{
+  if (!HasDolbyVisionProfile5())
+    return;
+
+  color_range = 1;
+
+  if (color_primaries == AVCOL_PRI_UNSPECIFIED)
+    color_primaries = AVCOL_PRI_BT2020;
+  if (m_originalColorPrimaries == AVCOL_PRI_UNSPECIFIED)
+    m_originalColorPrimaries = color_primaries;
+  if (color_transfer == AVCOL_TRC_UNSPECIFIED)
+    color_transfer = AVCOL_TRC_SMPTE2084;
+  if (color_space == AVCOL_SPC_UNSPECIFIED)
+    color_space = AVCOL_SPC_BT2020_NCL;
+}
