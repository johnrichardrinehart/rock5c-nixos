+bool CRendererDRMPRIMEGLES::InitPlacebo()
+{
+  if (m_placeboRenderer)
+    return true;
+
+  auto winSystem =
+      dynamic_cast<KODI::WINDOWING::LINUX::CWinSystemEGL*>(CServiceBroker::GetWinSystem());
+  if (!winSystem)
+    return false;
+
+  EGLDisplay eglDisplay = eglGetCurrentDisplay();
+  EGLContext eglContext = eglGetCurrentContext();
+  if (eglDisplay == EGL_NO_DISPLAY)
+    eglDisplay = winSystem->GetEGLDisplay();
+
+  if (eglContext == EGL_NO_CONTEXT)
+    return false;
+
+  static std::atomic_bool loggedContext{false};
+  bool expected = false;
+  if (loggedContext.compare_exchange_strong(expected, true))
+  {
+    const char* glVersion = reinterpret_cast<const char*>(glGetString(GL_VERSION));
+    const char* glVendor = reinterpret_cast<const char*>(glGetString(GL_VENDOR));
+    const char* glRenderer = reinterpret_cast<const char*>(glGetString(GL_RENDERER));
+    CLog::Log(LOGINFO,
+              "DRMPRIMEGLES: initializing libplacebo with EGL display {}, context {}, surface {}, "
+              "GL_VERSION={}, GL_VENDOR={}, GL_RENDERER={}",
+              fmt::ptr(eglDisplay), fmt::ptr(eglContext), fmt::ptr(eglGetCurrentSurface(EGL_DRAW)),
+              glVersion ? glVersion : "(null)", glVendor ? glVendor : "(null)",
+              glRenderer ? glRenderer : "(null)");
+  }
+
+  struct pl_log_params logParams = {};
+  logParams.log_cb = PlaceboLog;
+  logParams.log_level = PL_LOG_INFO;
+  m_placeboLog = pl_log_create(PL_API_VER, &logParams);
+  if (!m_placeboLog)
+    return false;
+
+  struct pl_opengl_params glParams = {};
+  glParams.get_proc_addr_ex = PlaceboGetProcAddress;
+  glParams.egl_display = eglDisplay;
+  glParams.egl_context = eglContext;
+  m_placeboGL = pl_opengl_create(m_placeboLog, &glParams);
+  if (!m_placeboGL)
+  {
+    DestroyPlacebo();
+    return false;
+  }
+
+  m_placeboRenderer = pl_renderer_create(m_placeboLog, m_placeboGL->gpu);
+  if (!m_placeboRenderer)
+  {
+    DestroyPlacebo();
+    return false;
+  }
+
+  return true;
+}
+
+void CRendererDRMPRIMEGLES::UnInit()
+{
+  if (auto winSystem = CServiceBroker::GetWinSystem())
+    winSystem->SetHDR(nullptr);
+  m_passthroughHDR = false;
+}
+
+void CRendererDRMPRIMEGLES::DestroyPlacebo()
+{
+  if (m_placeboGL)
+  {
+    for (auto& buf : m_buffers)
+      DestroyNv15ScratchTextures(buf);
+  }
+
+  if (m_placeboRenderer)
+    pl_renderer_destroy(&m_placeboRenderer);
+  if (m_placeboGL)
+    pl_opengl_destroy(&m_placeboGL);
+  if (m_placeboLog)
+    pl_log_destroy(&m_placeboLog);
+}
+
+void CRendererDRMPRIMEGLES::DestroyNv15ScratchTextures(BUFFER& buf)
+{
+  if (m_placeboGL)
+    ::DestroyNv15ScratchTextures(m_placeboGL->gpu, buf.nv15Textures, buf.nv15GLTextures);
+  else
+    ::DestroyNv15ScratchTextures(nullptr, buf.nv15Textures, buf.nv15GLTextures);
+
+  buf.nv15Width = 0;
+  buf.nv15Height = 0;
+}
