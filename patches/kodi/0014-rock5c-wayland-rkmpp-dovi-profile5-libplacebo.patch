+
+bool CRendererDRMPRIMEGLES::RenderPlacebo(CVideoBufferDRMPRIME* buffer, int index)
+{
+  AVFrame* avFrame = buffer->GetAVFrame();
+  if (!avFrame)
+  {
+    const uint64_t failures = ++m_profile5RenderFailures;
+    if (ShouldLogProfile5Anomaly(failures))
+    {
+      CLog::Log(LOGWARNING,
+                "DRMPRIMEGLES: Dolby Vision Profile 5 render has no AVFrame index={} failures={}",
+                index, failures);
+    }
+    return false;
+  }
+
+  const bool hasDoviSideData = av_frame_get_side_data(avFrame, AV_FRAME_DATA_DOVI_METADATA);
+  if (!hasDoviSideData)
+  {
+    const uint64_t missing = ++m_profile5MissingDoviSideData;
+    if (ShouldLogProfile5Anomaly(missing))
+    {
+      CLog::Log(LOGWARNING,
+                "DRMPRIMEGLES: Dolby Vision Profile 5 AVFrame is missing RPU side data "
+                "index={} pts={} drm_format=0x{:08x} missing={} frames={}",
+                index, FramePtsForLog(avFrame), DrmFormatForLog(avFrame), missing,
+                m_profile5Frames);
+    }
+    return false;
+  }
+
+  if (!InitPlacebo())
+  {
+    const uint64_t failures = ++m_profile5RenderFailures;
+    if (ShouldLogProfile5Anomaly(failures))
+    {
+      CLog::Log(LOGWARNING,
+                "DRMPRIMEGLES: failed to initialize libplacebo for Dolby Vision Profile 5 "
+                "index={} pts={} failures={}",
+                index, FramePtsForLog(avFrame), failures);
+    }
+    return false;
+  }
+
+  const int width = CServiceBroker::GetWinSystem()->GetGfxContext().GetWidth();
+  const int height = CServiceBroker::GetWinSystem()->GetGfxContext().GetHeight();
+
+  if (width <= 0 || height <= 0)
+  {
+    const uint64_t failures = ++m_profile5RenderFailures;
+    if (ShouldLogProfile5Anomaly(failures))
+    {
+      CLog::Log(LOGWARNING,
+                "DRMPRIMEGLES: invalid libplacebo target size for Dolby Vision Profile 5 "
+                "index={} pts={} size={}x{} failures={}",
+                index, FramePtsForLog(avFrame), width, height, failures);
+    }
+    return false;
+  }
+
+  struct pl_frame image = {};
+  std::unique_ptr<CEGLImage> manualEglImages[2];
+  struct pl_dovi_metadata dovi = {};
+  bool manualMap = false;
+  auto cleanupManualMap = [&]() {
+    for (auto& eglImage : manualEglImages)
+    {
+      if (eglImage)
+      {
+        eglImage->DestroyImage();
+        eglImage.reset();
+      }
+    }
+  };
+  struct pl_avframe_params frameParams = {};
+  frameParams.frame = avFrame;
+  frameParams.map_dovi = true;
+  auto getEglDisplay = []() {
+    EGLDisplay eglDisplay = eglGetCurrentDisplay();
+    if (eglDisplay != EGL_NO_DISPLAY)
+      return eglDisplay;
+
+    auto winSystem =
+        dynamic_cast<KODI::WINDOWING::LINUX::CWinSystemEGL*>(CServiceBroker::GetWinSystem());
+    return winSystem ? winSystem->GetEGLDisplay() : EGL_NO_DISPLAY;
+  };
+
+  const bool isRkmppNv15 = IsRkmppNv15DrmPrimeFrame(avFrame);
+  if (isRkmppNv15)
+  {
+    BUFFER& renderBuffer = m_buffers[index];
+    manualMap = MapRkmppNv15DrmPrimeFrame(m_placeboGL->gpu, getEglDisplay(), avFrame, &image,
+                                          renderBuffer.nv15Textures, renderBuffer.nv15GLTextures,
+                                          renderBuffer.nv15Width, renderBuffer.nv15Height,
+                                          manualEglImages, &dovi);
+    if (!manualMap)
+    {
+      cleanupManualMap();
+      CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to map RKMPP NV15 Dolby Vision AVFrame");
+      return true;
+    }
+  }
+
+  if (!manualMap && !pl_map_avframe_ex(m_placeboGL->gpu, &image, &frameParams))
+  {
+    cleanupManualMap();
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: libplacebo failed to map Dolby Vision AVFrame");
+    return true;
+  }
+
+  struct pl_opengl_wrap_params targetParams = {};
+  targetParams.width = width;
+  targetParams.height = height;
+  pl_tex targetTexture = pl_opengl_wrap(m_placeboGL->gpu, &targetParams);
+  if (!targetTexture)
+  {
+    if (manualMap)
+      cleanupManualMap();
+    else
+      pl_unmap_avframe(m_placeboGL->gpu, &image);
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to wrap Kodi framebuffer for libplacebo");
+    return false;
+  }
+
+  struct pl_frame target = {};
+  target.num_planes = 1;
+  target.planes[0].texture = targetTexture;
+  target.planes[0].flipped = true;
+  target.planes[0].components = 4;
+  target.planes[0].component_mapping[0] = 0;
+  target.planes[0].component_mapping[1] = 1;
+  target.planes[0].component_mapping[2] = 2;
+  target.planes[0].component_mapping[3] = 3;
+  target.crop.x0 = m_destRect.x1;
+  target.crop.y0 = m_destRect.y1;
+  target.crop.x1 = m_destRect.x2;
+  target.crop.y1 = m_destRect.y2;
+  target.repr.sys = PL_COLOR_SYSTEM_RGB;
+  target.repr.levels = PL_COLOR_LEVELS_FULL;
+  target.color.primaries = m_passthroughHDR ? PL_COLOR_PRIM_BT_2020 : PL_COLOR_PRIM_BT_709;
+  target.color.transfer = m_passthroughHDR ? PL_COLOR_TRC_PQ : PL_COLOR_TRC_SRGB;
+
+  bool ok = pl_render_image(m_placeboRenderer, &image, &target, &pl_render_default_params);
+  if (!ok)
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: libplacebo failed to render Dolby Vision frame");
+
+  pl_tex_destroy(m_placeboGL->gpu, &targetTexture);
+
+  if (manualMap)
+    cleanupManualMap();
+  else
+    pl_unmap_avframe(m_placeboGL->gpu, &image);
+
+  if (!ok)
+    return false;
+
+  BUFFER& renderBuffer = m_buffers[index];
+  renderBuffer.fence->DestroyFence();
+  renderBuffer.fence->CreateFence();
+  glFlush();
+  return true;
+}
