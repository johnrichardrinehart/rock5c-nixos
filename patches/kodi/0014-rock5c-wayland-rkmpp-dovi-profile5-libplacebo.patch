+void CRendererDRMPRIMEGLES::FinishSkippedProfile5Buffer(int index)
+{
+  BUFFER& buf = m_buffers[index];
+  if (buf.fence)
+  {
+    buf.fence->DestroyFence();
+    buf.fence->CreateFence();
+  }
