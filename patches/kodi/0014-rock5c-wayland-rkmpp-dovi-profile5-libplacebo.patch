+void PlaceboLog(void*, enum pl_log_level level, const char* msg)
+{
+  int kodiLevel = LOGDEBUG;
+
+  if (level <= PL_LOG_ERR)
+    kodiLevel = LOGERROR;
+  else if (level == PL_LOG_WARN)
+    kodiLevel = LOGWARNING;
+  else if (level == PL_LOG_INFO)
+    kodiLevel = LOGINFO;
+
+  CLog::Log(kodiLevel, "libplacebo: {}", msg);
+}
+
+pl_voidfunc_t PlaceboGetProcAddress(void*, const char* procname)
+{
+  auto proc = reinterpret_cast<pl_voidfunc_t>(eglGetProcAddress(procname));
+  if (proc)
+    return proc;
+
+  proc = reinterpret_cast<pl_voidfunc_t>(dlsym(RTLD_DEFAULT, procname));
+  if (proc)
+    return proc;
+
+  static void* gles = dlopen("libGLESv2.so.2", RTLD_LAZY | RTLD_LOCAL);
+  if (gles)
+  {
+    proc = reinterpret_cast<pl_voidfunc_t>(dlsym(gles, procname));
+    if (proc)
+      return proc;
+  }
+
+  static void* egl = dlopen("libEGL.so.1", RTLD_LAZY | RTLD_LOCAL);
+  if (egl)
+    return reinterpret_cast<pl_voidfunc_t>(dlsym(egl, procname));
+
+  return nullptr;
+}
+
+bool ShouldLogProfile5Anomaly(uint64_t count)
+{
+  return count <= 16 || count % 120 == 0;
+}
+
+int64_t FramePtsForLog(const AVFrame* frame)
+{
+  if (!frame)
+    return AV_NOPTS_VALUE;
+  if (frame->best_effort_timestamp != AV_NOPTS_VALUE)
+    return frame->best_effort_timestamp;
+  return frame->pts;
+}
+
+uint32_t DrmFormatForLog(const AVFrame* frame)
+{
+  if (!frame || frame->format != AV_PIX_FMT_DRM_PRIME || !frame->data[0])
+    return 0;
+
+  const auto* drm = reinterpret_cast<const AVDRMFrameDescriptor*>(frame->data[0]);
+  if (!drm || drm->nb_layers <= 0)
+    return 0;
+
+  return drm->layers[0].format;
+}
+
+bool IsRkmppNv15DrmPrimeFrame(const AVFrame* frame)
+{
+  if (!frame || frame->format != AV_PIX_FMT_DRM_PRIME || !frame->hw_frames_ctx || !frame->data[0])
+    return false;
+
+  const auto* hwFrames = reinterpret_cast<const AVHWFramesContext*>(frame->hw_frames_ctx->data);
+  const auto* drm = reinterpret_cast<const AVDRMFrameDescriptor*>(frame->data[0]);
+  if (!hwFrames || hwFrames->sw_format != AV_PIX_FMT_P010LE || !drm)
+    return false;
+
+  if (drm->nb_objects != 1 || drm->nb_layers != 1)
+    return false;
+
+  const auto& layer = drm->layers[0];
+  return layer.format == DRM_FORMAT_NV15 && layer.nb_planes == 2 &&
+         layer.planes[0].object_index >= 0 && layer.planes[0].object_index < drm->nb_objects &&
+         layer.planes[1].object_index >= 0 && layer.planes[1].object_index < drm->nb_objects;
+}
+
+GLuint CompileShader(GLenum type, const char* source)
+{
+  GLuint shader = glCreateShader(type);
+  glShaderSource(shader, 1, &source, nullptr);
+  glCompileShader(shader);
+
+  GLint ok = GL_FALSE;
+  glGetShaderiv(shader, GL_COMPILE_STATUS, &ok);
+  if (ok)
+    return shader;
+
+  char log[1024] = {};
+  glGetShaderInfoLog(shader, sizeof(log), nullptr, log);
+  CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to compile NV15 unpack shader: {}", log);
+  glDeleteShader(shader);
+  return 0;
+}
+
+GLuint LinkProgram(const char* vertexSource, const char* fragmentSource)
+{
+  GLuint vertexShader = CompileShader(GL_VERTEX_SHADER, vertexSource);
+  GLuint fragmentShader = CompileShader(GL_FRAGMENT_SHADER, fragmentSource);
+  if (!vertexShader || !fragmentShader)
+  {
+    glDeleteShader(vertexShader);
+    glDeleteShader(fragmentShader);
+    return 0;
+  }
+
+  GLuint program = glCreateProgram();
+  glAttachShader(program, vertexShader);
+  glAttachShader(program, fragmentShader);
+  glLinkProgram(program);
+  glDeleteShader(vertexShader);
+  glDeleteShader(fragmentShader);
+
+  GLint ok = GL_FALSE;
+  glGetProgramiv(program, GL_LINK_STATUS, &ok);
+  if (ok)
+    return program;
+
+  char log[1024] = {};
+  glGetProgramInfoLog(program, sizeof(log), nullptr, log);
+  CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to link NV15 unpack shader: {}", log);
+  glDeleteProgram(program);
+  return 0;
+}
+
+bool UnpackRkmppNv15Plane(GLuint srcTexture,
+                          GLuint dstTexture,
+                          int width,
+                          int height,
+                          bool chroma)
+{
+  static constexpr const char* vertexSource = R"(#version 300 es
+precision highp float;
+out vec2 texCoord;
+void main()
+{
+  vec2 pos = vec2(float((gl_VertexID << 1) & 2), float(gl_VertexID & 2));
+  texCoord = pos;
+  gl_Position = vec4(pos * 2.0 - 1.0, 0.0, 1.0);
+}
+)";
+
+  static constexpr const char* lumaFragmentSource = R"(#version 300 es
+precision highp float;
+precision highp int;
+precision highp usampler2D;
+uniform sampler2D src;
+uniform int srcHeight;
+out vec4 outColor;
+
+uint fetchByte(ivec2 coord)
+{
+  return uint(texelFetch(src, coord, 0).r * 255.0 + 0.5);
+}
+
+uint unpack10(int sampleIndex, int y)
+{
+  int bit = sampleIndex * 10;
+  int byteCoord = bit / 8;
+  uint shift = uint(bit - byteCoord * 8);
+  uint lo = fetchByte(ivec2(byteCoord, y));
+  uint hi = fetchByte(ivec2(byteCoord + 1, y));
+  return ((lo >> shift) | (hi << (8u - shift))) & 1023u;
+}
+
+void main()
+{
+  ivec2 p = ivec2(gl_FragCoord.xy);
+  int srcY = p.y;
+  outColor = vec4(float(unpack10(p.x, srcY)) / 1023.0, 0.0, 0.0, 1.0);
+}
+)";
+
+  static constexpr const char* chromaFragmentSource = R"(#version 300 es
+precision highp float;
+precision highp int;
+uniform sampler2D src;
+uniform int srcHeight;
+out vec4 outColor;
+
+uint fetchByte(ivec2 coord)
+{
+  return uint(texelFetch(src, coord, 0).r * 255.0 + 0.5);
+}
+
+uint unpack10(int sampleIndex, int y)
+{
+  int bit = sampleIndex * 10;
+  int byteCoord = bit / 8;
+  uint shift = uint(bit - byteCoord * 8);
+  uint lo = fetchByte(ivec2(byteCoord, y));
+  uint hi = fetchByte(ivec2(byteCoord + 1, y));
+  return ((lo >> shift) | (hi << (8u - shift))) & 1023u;
+}
+
+void main()
+{
+  ivec2 p = ivec2(gl_FragCoord.xy);
+  int srcY = p.y;
+  int sampleIndex = p.x * 2;
+  float cb = float(unpack10(sampleIndex, srcY)) / 1023.0;
+  float cr = float(unpack10(sampleIndex + 1, srcY)) / 1023.0;
+  outColor = vec4(cb, cr, 0.0, 1.0);
+}
+)";
+
+  static GLuint lumaProgram = 0;
+  static GLuint chromaProgram = 0;
+  GLuint& cachedProgram = chroma ? chromaProgram : lumaProgram;
+  if (!cachedProgram)
+    cachedProgram = LinkProgram(vertexSource, chroma ? chromaFragmentSource : lumaFragmentSource);
+
+  GLuint program = cachedProgram;
+  if (!program)
+    return false;
+
+  static GLuint framebuffer = 0;
+  if (!framebuffer)
+    glGenFramebuffers(1, &framebuffer);
+
+  glBindFramebuffer(GL_FRAMEBUFFER, framebuffer);
+  glFramebufferTexture2D(GL_FRAMEBUFFER, GL_COLOR_ATTACHMENT0, GL_TEXTURE_2D, dstTexture, 0);
+  if (glCheckFramebufferStatus(GL_FRAMEBUFFER) != GL_FRAMEBUFFER_COMPLETE)
+  {
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: NV15 unpack framebuffer is incomplete");
+    glBindFramebuffer(GL_FRAMEBUFFER, 0);
+    return false;
+  }
+
+  GLint oldViewport[4] = {};
+  glGetIntegerv(GL_VIEWPORT, oldViewport);
+  glViewport(0, 0, width, height);
+  glUseProgram(program);
+  glActiveTexture(GL_TEXTURE0);
+  glBindTexture(GL_TEXTURE_2D, srcTexture);
+  glUniform1i(glGetUniformLocation(program, "src"), 0);
+  glUniform1i(glGetUniformLocation(program, "srcHeight"), height);
+  glDrawArrays(GL_TRIANGLES, 0, 3);
+  glBindTexture(GL_TEXTURE_2D, 0);
+  glUseProgram(0);
+  glViewport(oldViewport[0], oldViewport[1], oldViewport[2], oldViewport[3]);
+  glBindFramebuffer(GL_FRAMEBUFFER, 0);
+  return true;
+}
+
+void DestroyNv15ScratchTextures(pl_gpu gpu, pl_tex textures[2], GLuint glTextures[2])
+{
+  if (gpu)
+  {
+    pl_tex_destroy(gpu, &textures[1]);
+    pl_tex_destroy(gpu, &textures[0]);
+  }
+
+  if (glTextures[0] || glTextures[1])
+    glDeleteTextures(2, glTextures);
+
+  textures[0] = nullptr;
+  textures[1] = nullptr;
+  glTextures[0] = 0;
+  glTextures[1] = 0;
+}
+
+bool EnsureRkmppNv15ScratchTextures(pl_gpu gpu,
+                                    int width,
+                                    int height,
+                                    pl_tex textures[2],
+                                    GLuint glTextures[2],
+                                    int& textureWidth,
+                                    int& textureHeight)
+{
+  if (!gpu || width <= 0 || height <= 0)
+    return false;
+
+  if (textureWidth == width && textureHeight == height && textures[0] && textures[1] &&
+      glTextures[0] && glTextures[1])
+    return true;
+
+  DestroyNv15ScratchTextures(gpu, textures, glTextures);
+
+  glGenTextures(2, glTextures);
+  glBindTexture(GL_TEXTURE_2D, glTextures[0]);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+  glTexImage2D(GL_TEXTURE_2D, 0, GL_R16F, width, height, 0, GL_RED, GL_HALF_FLOAT, nullptr);
+
+  glBindTexture(GL_TEXTURE_2D, glTextures[1]);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
+  glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+  glTexImage2D(GL_TEXTURE_2D, 0, GL_RG16F, (width + 1) / 2, (height + 1) / 2, 0, GL_RG,
+               GL_HALF_FLOAT, nullptr);
+  glBindTexture(GL_TEXTURE_2D, 0);
+
+  pl_opengl_wrap_params yParams = {};
+  yParams.texture = glTextures[0];
+  yParams.width = width;
+  yParams.height = height;
+  yParams.target = GL_TEXTURE_2D;
+  yParams.iformat = GL_R16F;
+  textures[0] = pl_opengl_wrap(gpu, &yParams);
+  if (!textures[0])
+  {
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to wrap RKMPP NV15 luma texture");
+    DestroyNv15ScratchTextures(gpu, textures, glTextures);
+    return false;
+  }
+
+  pl_opengl_wrap_params uvParams = {};
+  uvParams.texture = glTextures[1];
+  uvParams.width = (width + 1) / 2;
+  uvParams.height = (height + 1) / 2;
+  uvParams.target = GL_TEXTURE_2D;
+  uvParams.iformat = GL_RG16F;
+  textures[1] = pl_opengl_wrap(gpu, &uvParams);
+  if (!textures[1])
+  {
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to wrap RKMPP NV15 chroma texture");
+    DestroyNv15ScratchTextures(gpu, textures, glTextures);
+    return false;
+  }
+
+  textureWidth = width;
+  textureHeight = height;
+  return true;
+}
+
+bool MapRkmppNv15DrmPrimeFrame(pl_gpu gpu,
+                               EGLDisplay eglDisplay,
+                               AVFrame* frame,
+                               pl_frame* image,
+                               pl_tex textures[2],
+                               GLuint glTextures[2],
+                               int& textureWidth,
+                               int& textureHeight,
+                               std::unique_ptr<CEGLImage> eglImages[2],
+                               pl_dovi_metadata* dovi)
+{
+  if (!gpu || eglDisplay == EGL_NO_DISPLAY || !IsRkmppNv15DrmPrimeFrame(frame))
+    return false;
+
+  const auto* drm = reinterpret_cast<const AVDRMFrameDescriptor*>(frame->data[0]);
+  const auto& layer = drm->layers[0];
+  const auto& yPlane = layer.planes[0];
+  const auto& uvPlane = layer.planes[1];
+  const auto& yObject = drm->objects[yPlane.object_index];
+  const auto& uvObject = drm->objects[uvPlane.object_index];
+
+  pl_frame_from_avframe(image, frame);
+  pl_plane_data planeData[4] = {};
+  pl_plane_data_from_pixfmt(planeData, &image->repr.bits, AV_PIX_FMT_P010LE);
+  image->repr.bits.sample_depth = 10;
+  image->repr.bits.color_depth = 10;
+  image->repr.bits.bit_shift = 0;
+
+  if (AVFrameSideData* sd = av_frame_get_side_data(frame, AV_FRAME_DATA_DOVI_METADATA))
+    pl_map_avdovi_metadata(&image->color, &image->repr, dovi,
+                           reinterpret_cast<const AVDOVIMetadata*>(sd->data));
+
+  eglImages[0] = std::make_unique<CEGLImage>(eglDisplay);
+  CEGLImage::EglAttrs yAttrs;
+  yAttrs.width = static_cast<int>(yPlane.pitch);
+  yAttrs.height = frame->height;
+  yAttrs.format = DRM_FORMAT_R8;
+  yAttrs.planes[0].fd = yObject.fd;
+  yAttrs.planes[0].offset = static_cast<int>(yPlane.offset);
+  yAttrs.planes[0].pitch = static_cast<int>(yPlane.pitch);
+  yAttrs.planes[0].modifier = yObject.format_modifier;
+  if (!eglImages[0]->CreateImage(yAttrs))
+  {
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to import RKMPP NV15 luma EGL image");
+    eglImages[0].reset();
+    return false;
+  }
+
+  eglImages[1] = std::make_unique<CEGLImage>(eglDisplay);
+  CEGLImage::EglAttrs uvAttrs;
+  uvAttrs.width = static_cast<int>(uvPlane.pitch);
+  uvAttrs.height = (frame->height + 1) / 2;
+  uvAttrs.format = DRM_FORMAT_R8;
+  uvAttrs.planes[0].fd = uvObject.fd;
+  uvAttrs.planes[0].offset = static_cast<int>(uvPlane.offset);
+  uvAttrs.planes[0].pitch = static_cast<int>(uvPlane.pitch);
+  uvAttrs.planes[0].modifier = uvObject.format_modifier;
+  if (!eglImages[1]->CreateImage(uvAttrs))
+  {
+    CLog::Log(LOGWARNING, "DRMPRIMEGLES: failed to import RKMPP NV15 chroma EGL image");
+    eglImages[1].reset();
+    return false;
+  }
+
+  GLuint srcTextures[2] = {};
+  glGenTextures(2, srcTextures);
+  for (int i = 0; i < 2; ++i)
+  {
+    glBindTexture(GL_TEXTURE_2D, srcTextures[i]);
+    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MIN_FILTER, GL_LINEAR);
+    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_MAG_FILTER, GL_LINEAR);
+    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_S, GL_CLAMP_TO_EDGE);
+    glTexParameteri(GL_TEXTURE_2D, GL_TEXTURE_WRAP_T, GL_CLAMP_TO_EDGE);
+    eglImages[i]->UploadImage(GL_TEXTURE_2D);
+  }
+  glBindTexture(GL_TEXTURE_2D, 0);
+
+  if (!EnsureRkmppNv15ScratchTextures(gpu, frame->width, frame->height, textures, glTextures,
+                                      textureWidth, textureHeight))
+  {
+    glDeleteTextures(2, srcTextures);
+    return false;
+  }
+
+  bool unpacked = UnpackRkmppNv15Plane(srcTextures[0], glTextures[0], frame->width, frame->height,
+                                       false) &&
+                  UnpackRkmppNv15Plane(srcTextures[1], glTextures[1], (frame->width + 1) / 2,
+                                       (frame->height + 1) / 2, true);
+  glDeleteTextures(2, srcTextures);
+  for (int i = 0; i < 2; ++i)
+  {
+    if (eglImages[i])
+    {
+      eglImages[i]->DestroyImage();
+      eglImages[i].reset();
+    }
+  }
+
+  if (!unpacked)
+    return false;
+
+  image->planes[0].texture = textures[0];
+  image->planes[1].texture = textures[1];
+  return true;
+}
